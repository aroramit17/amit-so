---
import BaseLayout from '../layouts/BaseLayout.astro';
import SITE_DATA from '../data/site.js';
import '../styles/case-study.css';

const caseStudies = SITE_DATA.caseStudies || [];
const siteUrl = `https://${SITE_DATA.domain}`;
const description = `Selected case studies from ${SITE_DATA.name}'s work — each with context, approach, and outcomes.`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Case Studies",
  "url": `${siteUrl}/case-studies`,
  "description": description,
  "isPartOf": {
    "@type": "WebSite",
    "name": SITE_DATA.name,
    "url": siteUrl
  },
  "hasPart": caseStudies.map((c) => ({
    "@type": "CreativeWork",
    "name": c.title,
    "url": `${siteUrl}/${c.slug}`,
    "about": c.tag
  }))
});
---
<BaseLayout
  title={`Case Studies | ${SITE_DATA.name}`}
  description={description}
  canonical={`${siteUrl}/case-studies`}
  jsonLd={jsonLd}
>
  <div class="grain"></div>

  <nav>
    <a href="/" class="nav-brand">{SITE_DATA.domain}</a>
    <a href="/" class="nav-back">&larr; Back to Portfolio</a>
  </nav>

  <main>
    <div class="eyebrow">Selected Work</div>
    <h1>Case Studies</h1>
    <p class="cs-sub">A deeper look at a few engagements — the context, the approach, and the outcome. New studies added as they're written up.</p>

    <div class="cs-list">
      {caseStudies.map((c) => (
        <a href={`/${c.slug}`} class="cs-list-card">
          <span class="cs-list-tag">{c.tag}</span>
          <h2 class="cs-list-title">{c.title}</h2>
          <p class="cs-list-blurb">{c.blurb}</p>
          <span class="cs-list-arrow">Read the story &rarr;</span>
        </a>
      ))}
    </div>

    <div class="cs-cta">
      <h3>Have a similar problem?</h3>
      <p>If any of these engagements map to work you're scoping, let's talk.</p>
      <a href="/interview" class="cs-cta-btn">Book a Call &rarr;</a>
    </div>
  </main>

  <footer>
    &copy; {SITE_DATA.copyrightYear} {SITE_DATA.name} &middot; <a href="/">{SITE_DATA.domain}</a> &middot; <a href="/privacy">Privacy</a> &middot; <a href="#" onclick="event.preventDefault(); window.showCookiePreferences && window.showCookiePreferences();">Cookies</a>
  </footer>
</BaseLayout>
