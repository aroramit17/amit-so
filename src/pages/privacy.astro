---
import BaseLayout from '../layouts/BaseLayout.astro';
import SITE_DATA from '../data/site.js';
import '../styles/privacy.css';

const siteUrl = `https://${SITE_DATA.domain}`;
const description = `Privacy Policy for ${SITE_DATA.domain} — how cookies, tracking technologies, and online data partners are used on this site, and how visitors can opt out.`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy",
  "url": `${siteUrl}/privacy`,
  "description": description,
  "isPartOf": {
    "@type": "WebSite",
    "name": SITE_DATA.name,
    "url": siteUrl
  },
  "about": {
    "@type": "Person",
    "name": SITE_DATA.name,
    "url": siteUrl
  }
});
---
<BaseLayout
  title={`Privacy Policy | ${SITE_DATA.name}`}
  description={description}
  canonical={`${siteUrl}/privacy`}
  jsonLd={jsonLd}
>
  <div class="grain"></div>

  <nav>
    <a href="/" class="nav-brand">{SITE_DATA.domain}</a>
    <a href="/" class="nav-back">&larr; Back to Portfolio</a>
  </nav>

  <main>
    <div class="eyebrow">Legal</div>
    <h1>Privacy Policy</h1>
    <p class="updated">Last updated: April 23, 2026</p>

    <p>This Privacy Policy describes how information is collected when you visit <strong>{SITE_DATA.domain}</strong> (the &ldquo;Site&rdquo;). By using the Site, you agree to the practices described below.</p>

    <h2>Cookie Consent</h2>
    <p>When you first visit the Site, a banner asks whether you accept the use of cookies and similar analytics technologies. Nothing described in the sections below loads until you click <strong>Accept</strong>. If you click <strong>Decline</strong>, the Site continues to function normally without loading any third-party analytics or identification scripts.</p>
    <p>You can change your choice at any time by clicking <a class="inline" href="#" onclick="event.preventDefault(); window.showCookiePreferences && window.showCookiePreferences();">Cookies</a> in the footer. Revocation takes effect on the next page load.</p>

    <h2>Product Analytics &mdash; Microsoft Clarity</h2>
    <p>If you accept cookies, the Site loads <strong>Microsoft Clarity</strong> to help understand how visitors use it. Clarity captures session recordings (mouse movement, scrolls, clicks, and the pages you view), heatmaps, and basic device and browser information. Clarity uses first-party cookies to group events in a single session. Form field contents, email addresses, and other sensitive inputs are masked by default and are not visible in recordings.</p>
    <p>Microsoft is the data controller for the information Clarity collects. For details on what is collected and how it is handled, see the <a class="inline" href="https://learn.microsoft.com/en-us/clarity/setup-and-installation/faq#privacy-information" target="_blank" rel="noopener">Clarity privacy FAQ</a> and the <a class="inline" href="https://privacy.microsoft.com/privacystatement" target="_blank" rel="noopener">Microsoft Privacy Statement</a>.</p>

    <h2>Online Data Partners</h2>
    <p>When you visit the Site, cookies and similar technologies may be used by our online data partners or vendors to associate these activities with other personal information they or others have about you, including by association with your email. We (or service providers on our behalf) may then send communications and marketing to these email addresses. You may opt out of receiving this advertising by visiting <a class="inline" href="https://app.retention.com/optout" target="_blank" rel="noopener">https://app.retention.com/optout</a>.</p>

    <h2>Contact</h2>
    <p>For questions about this Privacy Policy or how your data is handled, reach out at <a class="inline" href={`mailto:${SITE_DATA.contactEmail}`}>{SITE_DATA.contactEmail}</a>.</p>
  </main>

  <footer>
    &copy; {SITE_DATA.copyrightYear} {SITE_DATA.name} &middot; <a href="/">{SITE_DATA.domain}</a> &middot; <a href="#" onclick="event.preventDefault(); window.showCookiePreferences && window.showCookiePreferences();">Cookies</a>
  </footer>
</BaseLayout>
