---
import BaseLayout from '../layouts/BaseLayout.astro';
import SITE_DATA from '../data/site.js';
import '../styles/interview.css';

const siteUrl = `https://${SITE_DATA.domain}`;
const calLink = SITE_DATA.calLink || '';
const calNamespace = (calLink.split('/')[1] || 'intro').replace(/[^a-z0-9-]/gi, '-');
const firstName = SITE_DATA.name.split(' ')[0];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "name": `Book a call with ${SITE_DATA.name}`,
      "url": `${siteUrl}/interview`,
      "description": SITE_DATA.interviewLede,
      "isPartOf": {
        "@type": "WebSite",
        "name": SITE_DATA.name,
        "url": siteUrl
      }
    },
    {
      "@type": "Person",
      "name": SITE_DATA.name,
      "url": siteUrl,
      "image": `${siteUrl}/headshot.png`,
      "jobTitle": SITE_DATA.experience?.[0]?.role || "",
      "sameAs": [
        SITE_DATA.social?.linkedin,
        SITE_DATA.social?.youtube
      ].filter(Boolean)
    }
  ]
});
---
<BaseLayout
  title={`Book a call with ${SITE_DATA.name}`}
  description={SITE_DATA.interviewLede}
  canonical={`${siteUrl}/interview`}
  jsonLd={jsonLd}
  showFloatingCta={false}
>
  <div class="grain"></div>

  <nav>
    <a href="/" class="nav-brand">{SITE_DATA.domain}</a>
    <a href="/" class="nav-back">&larr; Back to Portfolio</a>
  </nav>

  <main>
    {SITE_DATA.interviewBadge && (
      <div class="interview-badge fade-up">{SITE_DATA.interviewBadge}</div>
    )}

    <h1 class="fade-up">Book a call with {firstName}</h1>

    <p class="interview-lede fade-up">{SITE_DATA.interviewLede}</p>

    {calLink && (
      <div class="cal-embed-wrap fade-up">
        <div id={`my-cal-inline-${calNamespace}`}></div>
      </div>
    )}

    <div class="interview-body fade-up">
      <h2 class="interview-h2">Who you&rsquo;d be talking to</h2>
      {(SITE_DATA.interviewBody || []).map((p) => <p set:html={p} />)}
    </div>

    <div class="social-links fade-up">
      {SITE_DATA.social?.linkedin && (
        <a href={SITE_DATA.social.linkedin} target="_blank" rel="noopener" class="social-link">LinkedIn</a>
      )}
      {SITE_DATA.social?.youtube && (
        <a href={SITE_DATA.social.youtube} target="_blank" rel="noopener" class="social-link">YouTube</a>
      )}
      {SITE_DATA.contactEmail && (
        <a href={`mailto:${SITE_DATA.contactEmail}`} class="social-link" aria-label={`Send ${SITE_DATA.name} an email`}>Email Me</a>
      )}
    </div>
  </main>

  <footer>
    &copy; {SITE_DATA.copyrightYear} {SITE_DATA.name} &middot; <a href="/">{SITE_DATA.domain}</a> &middot; <a href="/privacy">Privacy</a> &middot; <a href="#" onclick="event.preventDefault(); window.showCookiePreferences && window.showCookiePreferences();">Cookies</a>
  </footer>

  {calLink && (
    <script is:inline define:vars={{ calLink, calNamespace }} type="text/javascript">
      (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
      Cal("init", calNamespace, {origin:"https://app.cal.com"});
      Cal.ns[calNamespace]("inline", {
        elementOrSelector: "#my-cal-inline-" + calNamespace,
        config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
        calLink: calLink,
      });
      Cal.ns[calNamespace]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
    </script>
  )}
</BaseLayout>
